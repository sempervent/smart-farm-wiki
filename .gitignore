# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env
.env.*
!.env.example
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# MkDocs
site/

# OS / editors
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# Obsidian — local vault UI/settings; not part of the published corpus
.obsidian/

# User scratch (optional)
scratch/
tmp/

# Raw corpus (AGENTS.md): do not commit inbox drops or processed sources by default;
# directory layout is preserved via tracked .gitkeep files.
# (Git cannot re-include a file if a parent dir is excluded; un-ignore dirs then .gitkeep.)
raw/**
!raw/**/
!raw/**/.gitkeep
